# Studio Clyx — example environment file.
#
# Copy to `.env` for local dev, or set these in Render → Environment Variables
# for production. NEVER commit a filled-in `.env` with real secrets. All values
# here are safe placeholders. See ENV_SETUP.md and the *_HANDOFF.md docs.

# ---- Admin gate ----
# Operator PIN for /#/admin. Without it the gate falls back to "0000" (preview).
ADMIN_PIN=0000

# ---- Resend (transactional booking email + inbound receiving) ----
# https://resend.com/api-keys — provide via the host's secret manager.
RESEND_API_KEY=
RESEND_FROM_ADDRESS='Studio Clyx <info@studioclyx.com>'
# Comma-separated owner recipients for new booking hold alerts.
OWNER_ALERT_EMAILS=calebdao@gmail.com,gladys@example.com
# Single recipient for the "hold still pending after 1 hour" reminder.
OWNER_REMINDER_EMAIL=info@calebgladys.com

# ---- Google Calendar (one calendar per space) ----
# Service-account JSON on a single line. Used by the Calendar client.
GOOGLE_SERVICE_ACCOUNT_JSON=
# Each space's calendar ID (these are not secrets):
GOOGLE_CALENDAR_ID_STUDIO_1=
GOOGLE_CALENDAR_ID_STUDIO_2=
GOOGLE_CALENDAR_ID_STUDIO_3=
GOOGLE_CALENDAR_ID_LINCOLN_APARTMENT=

# ---- Stripe (card payments with customer-borne surcharge) ----
# See STRIPE_HANDOFF.md. Use a restricted key. Unset → Zelle works, card simulates.
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# ---- Peerspace email-reply agent (see AGENT_HANDOFF.md) ----
# Master kill switch — the agent only drafts replies when this is exactly "true".
AGENT_ENABLED=true
# Anthropic API key for Claude (drafting). Unset → simulation (placeholder drafts).
# https://console.anthropic.com
ANTHROPIC_API_KEY=
# Claude model used for drafting. Defaults to claude-sonnet-4-6 when unset.
AGENT_MODEL=claude-sonnet-4-6
# Auto-send: when "true", confident replies are emailed automatically (no manual
# approval). Off by default. The bot only auto-sends when it's confident the
# knowledge base covers the question AND the reply doesn't defer to a human;
# novel questions are flagged in the Inbox and you get an email alert instead.
AGENT_AUTO_SEND=false
# Auto-send booking ENTRY INSTRUCTIONS independently of Q&A replies. These are
# deterministic verbatim templates (no AI), so you can auto-send them on confirmed
# bookings while keeping AI replies in draft mode. (Also on if AGENT_AUTO_SEND=true.)
AGENT_AUTO_SEND_INSTRUCTIONS=true
# Gmail account linked to Peerspace. Used for BOTH reading inbound Peerspace
# emails (IMAP) and sending approved replies (SMTP). Needs 2-Step Verification +
# an app password (NOT the normal login password), and IMAP enabled in Gmail
# settings. Unset → inbound poller off and replies simulate (logged, not sent).
GMAIL_USER=calebandgladys@gmail.com
GMAIL_APP_PASSWORD=
# Optional inbound-poller tuning:
# Substring matched against the From header to pick out Peerspace mail so the
# poller never touches the account's other email (default "peerspace.com").
# PEERSPACE_SENDER_MATCH=peerspace.com
# Mailbox/label to read (default INBOX).
# AGENT_INBOX_FOLDER=INBOX
# Poll interval in seconds (default 60, minimum 30).
# AGENT_POLL_SECONDS=60
# Max emails handled per poll (default 5). Keeps memory bounded on small
# instances; a larger backlog drains across multiple polls.
# AGENT_MAX_PER_POLL=5
# Skip automated Peerspace notifications (booking confirmed, payment, review,
# etc.) so the bot only drafts replies to real guest messages. Override the
# default skip list (comma-separated subject substrings):
# PEERSPACE_IGNORE_SUBJECTS=is confirmed,booking request,payment received,leave a review
# Or, stricter: ONLY process subjects containing one of these (allowlist):
# PEERSPACE_MESSAGE_SUBJECTS=new message,sent you a message,inquiry
# Optional: override the knowledge-base path (defaults to docs/agent-knowledge.md).
# AGENT_KNOWLEDGE_PATH=

# ---- Storage ----
# Optional SQLite path override. In production point at a Render persistent disk
# (e.g. /var/data/data.db). Defaults to ./data.db.
# DATABASE_PATH=
